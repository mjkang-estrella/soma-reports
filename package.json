{
  "name": "soma-reports",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source genome report marketplace and agent-prompt runner inspired by sequencing.com/marketplace.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "convex:dev": "convex dev",
    "convex:once": "convex dev --once",
    "seed": "node scripts/seed-defaults.mjs",
    "catalog:extract": "node scripts/extract-sequencing-public-catalog.mjs --input tmp/sequencing-aggregate.html --json-out reference/catalog/sequencing-public-marketplace-catalog.json --ts-out convex/marketplaceCatalog.ts",
    "catalog:normalize-auth": "node scripts/normalize-authenticated-catalog.mjs",
    "catalog:assert": "node scripts/assert-catalog-coverage.mjs",
    "catalog:audit": "node scripts/audit-marketplace-status.mjs",
    "scaffold:evidence-audit": "node scripts/audit-scaffold-evidence.mjs",
    "scaffold:capture-plan": "node scripts/export-evidence-capture-plan.mjs",
    "scaffold:capture-template": "node scripts/export-official-output-capture-template.mjs",
    "scaffold:capture-templates": "node scripts/export-official-output-capture-templates.mjs",
    "scaffold:template-audit": "node scripts/audit-official-output-capture-templates.mjs",
    "scaffold:capture-status": "node scripts/summarize-official-output-capture-status.mjs",
    "scaffold:capture-status:snapshot": "node scripts/summarize-official-output-capture-status.mjs --allow-empty-captures true --out reference/catalog/official-output-capture-status.json",
    "scaffold:blueprint-audit": "node scripts/audit-formal-output-blueprint-coverage.mjs",
    "scaffold:next-actions": "node scripts/export-official-output-next-actions.mjs",
    "scaffold:capture-session": "node scripts/export-official-output-capture-session.mjs",
    "scaffold:public-endpoint-probe": "node scripts/probe-public-report-endpoints.mjs",
    "scaffold:validate-captures": "node scripts/validate-official-output-captures.mjs",
    "scaffold:privacy-canary": "node scripts/audit-official-output-capture-privacy-canary.mjs",
    "scaffold:promotion-preview": "node scripts/preview-official-output-promotion.mjs",
    "scaffold:promotion-verify": "node scripts/verify-official-output-promotion-applied.mjs",
    "scaffold:redaction-template": "node scripts/export-private-output-redaction-template.mjs",
    "scaffold:redaction-next": "node scripts/export-private-output-redaction-template.mjs --next true",
    "scaffold:sanitize-output": "node scripts/sanitize-private-output-capture.mjs",
    "objective:audit": "node scripts/audit-objective-coverage.mjs",
    "ui:audit": "node scripts/audit-rendered-marketplace-ui.mjs",
    "completion:audit": "node scripts/audit-completion-gate.mjs",
    "readiness:audit": "convex run reports:seedReadinessAudit",
    "readiness:audit:summary": "node scripts/summarize-readiness-audit.mjs",
    "agent:bundle": "node scripts/agent-bundle.mjs",
    "agent:seed-cache": "node scripts/export-local-artifact-seeds.mjs",
    "agent:evidence-template": "node scripts/export-local-evidence-template.mjs",
    "agent:derive-evidence": "node scripts/derive-local-evidence-from-genome.mjs",
    "agent:update-rsid-coordinate-map": "node scripts/update-rsid-coordinate-map.mjs",
    "agent:workflow-check": "node scripts/check-local-agent-workflow.mjs",
    "agent:local-run": "node scripts/run-local-genome-report.mjs",
    "agent:prepare-local": "node scripts/run-local-genome-report.mjs",
    "agent:generate-local-result": "node scripts/generate-local-agent-result.mjs",
    "agent:prepare": "node scripts/prepare-local-agent-run.mjs",
    "agent:validate-run": "node scripts/validate-local-agent-run.mjs",
    "agent:validate": "node scripts/agent-bundle.mjs",
    "agent:export": "node scripts/validate-local-packages.mjs --manifest-out tmp/agent-bundles/manifest.json",
    "agent:validate:all": "node scripts/validate-local-packages.mjs",
    "agent:validate:parity": "node scripts/validate-local-packages.mjs --validation-mode sample-parity",
    "agent:validate:formal": "node scripts/validate-local-packages.mjs --validation-mode formal-ready",
    "agent:smoke": "node scripts/smoke-local-evidence-workflow.mjs",
    "agent:assert-sync": "node scripts/assert-local-artifact-sync.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mjkang-estrella/soma-reports.git"
  },
  "keywords": [
    "genomics",
    "convex",
    "reports",
    "marketplace"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mjkang-estrella/soma-reports/issues"
  },
  "homepage": "https://github.com/mjkang-estrella/soma-reports#readme",
  "dependencies": {
    "convex": "^1.41.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "overrides": {
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
